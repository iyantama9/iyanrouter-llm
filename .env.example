CASTAI_API_KEYS=<YOUR_PRIMARY_API_KEY>,<YOUR_BACKUP_API_KEY_1>,<YOUR_BACKUP_API_KEY_2>,...
DEFAULT_UPSTREAM_URL=https://llm.kimchi.dev/openai/v1

PORT=4000

# Security (no hardcoded secrets in source)
ADMIN_PASSWORD=your_admin_password
ROUTER_PASSWORD=your_router_password

# SSL configurations (only set on remote VPS)
SSL_KEYFILE=/etc/letsencrypt/live/yourdomain.sslip.io/privkey.pem
SSL_CERTFILE=/etc/letsencrypt/live/yourdomain.sslip.io/fullchain.pem

# PostgreSQL Database (required)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Show reasoning content in responses
SHOW_REASONING=true

# Inject behavior normalization prompt to all models (thinking, task structure, formatting)
AUGMENT_SYSTEM_PROMPT=true

# Rotate key proactively if TTFT (streaming) or total time (non-streaming) exceeds this in ms. 0 = disabled.
SLOW_RESPONSE_THRESHOLD_MS=10000
