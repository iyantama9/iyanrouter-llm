CASTAI_API_KEYS=<YOUR_PRIMARY_API_KEY>,<YOUR_BACKUP_API_KEY_1>,<YOUR_BACKUP_API_KEY_2>,...
DEFAULT_UPSTREAM_URL=https://llm.kimchi.dev/openai/v1

PORT=4000

# Security (no hardcoded secrets in source)
ADMIN_PASSWORD=your_admin_password
ROUTER_PASSWORD=your_router_password

# SSL configurations (only set on remote VPS)
SSL_KEYFILE=/etc/letsencrypt/live/yourdomain.sslip.io/privkey.pem
SSL_CERTFILE=/etc/letsencrypt/live/yourdomain.sslip.io/fullchain.pem

# PostgreSQL Database (required)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Show reasoning content in responses
SHOW_REASONING=true

# Inject behavior normalization prompt to all models (thinking, task structure, formatting)
AUGMENT_SYSTEM_PROMPT=true

# Rotate key proactively if TTFT (streaming) or total time (non-streaming) exceeds this in ms. 0 = disabled.
SLOW_RESPONSE_THRESHOLD_MS=10000

# Auto-reset "Limited" keys back to Standby after this many minutes. 0 = disabled.
LIMIT_COOLDOWN_MINUTES=60

# byNara provider
NARA_BASE_URL=https://router.bynara.id/v1
NARA_API_KEYS=sk-nry-key1,sk-nry-key2
NARA_MODELS=claude-sonnet-5,claude-opus-4.8,claude-fable-5,claude-opus-4.7,gpt-5.5,gpt-5.4,kimi-k2.7-code,deepseek-v4-pro,minimax-m3,glm-5.2

# Dahl provider
DAHL_BASE_URL=https://inference.dahl.global/v1
DAHL_API_KEYS=dahl_key1,dahl_key2,dahl_key3,dahl_key4,dahl_key5,dahl_key6,dahl_key7,dahl_key8
DAHL_MODELS=MiniMaxAI/MiniMax-M2.7,moonshotai/Kimi-K2.6,zai-org/GLM-5.2-FP8
# Router exposes these as dh/<short-name> (vendor prefix is stripped automatically)

# Qwen Cloud provider
QWEN_CLOUD_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_CLOUD_API_KEYS=sk-ws-key1,sk-ws-key2
QWEN_CLOUD_MODELS=qwen-plus,qwen-max,qwen-turbo,qwen3-235b-a22b,qwen3-max,qwen3-coder-plus,qwen-vl-max,deepseek-v3.2,glm-5.2,kimi-k2.7-code
# Per-model fallback order when ALL keys have exhausted the requested model
QC_FALLBACK_ORDER=qwen3.7-max,qwen-max,qwen-plus,deepseek-v3.2,glm-5.2,kimi-k2.7-code,qwen-turbo
